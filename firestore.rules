rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Sizin kullanıcı kimliğiniz ve admin e-postanız için kesin yetkilendirme
      return isSignedIn() && (
        request.auth.uid == "xK5gYcZ4kSY7AoNolrCZFL9npSG2" ||
        request.auth.token.email == "bamm@admin.com" ||
        request.auth.token.email == "berattasoz31@gmail.com" ||
        request.auth.token.email == "bammyonetici@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- MenuItem Validation ---
    function isValidMenuItem(data) {
      // Temel zorunlu alanlar ve tip kontrolleri
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is string && data.price.size() > 0 && data.price.size() <= 30 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 60 &&
             // Opsiyonel alanlar için tip, varlık ve boyut koruması (null veya eksik durumları kapsar)
             (data.get('description', null) == null || (data.description is string && data.description.size() <= 1000)) &&
             (data.get('subcategory', null) == null || (data.subcategory is string && data.subcategory.size() <= 100)) &&
             (data.get('image', null) == null || (data.image is string && data.image.size() <= 10485760)) &&
             (data.get('isPopular', null) == null || data.isPopular is bool) &&
             (data.get('deleted', null) == null || data.deleted is bool);
    }

    // --- Category Validation ---
    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.order is int || data.order is float) &&
             (data.get('description', null) == null || (data.description is string && data.description.size() <= 1000)) &&
             (data.get('image', null) == null || (data.image is string && data.image.size() <= 10485760)) &&
             (data.get('deleted', null) == null || data.deleted is bool) &&
             (data.get('id', null) == null || (data.id is string && data.id.size() <= 128));
    }

    // --- Collections ---

    match /categories/{categoryId} {
      allow read: if true; // Herkes kategorileri okuyabilir
      allow write: if isAdmin(); // Sadece yetkili yöneticiler yazabilir
    }

    match /products/{productId} {
      allow read: if true; // Herkes ürünleri okuyabilir
      allow write: if isAdmin(); // Sadece yetkili yöneticiler yazabilir
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via Admin SDK or Console
    }
  }
}
