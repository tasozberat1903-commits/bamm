{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item in the cafe menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "image": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "deleted": { "type": "boolean" }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "A menu category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "description": { "type": "string" },
        "deleted": { "type": "boolean" }
      },
      "required": ["name", "order"]
    }
  },
  "firestore": {
    "products": {
      "schema": "MenuItem",
      "description": "Collection of all menu items"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of upper menu categories"
    },
    "admins": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        }
      },
      "description": "Authorized administrators"
    }
  }
}
