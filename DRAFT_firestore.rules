rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "bamm@admin.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- MenuItem Validation ---
    function isValidMenuItem(data) {
      let requiredFields = ['name', 'price', 'category'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is string && data.price.size() > 0 && data.price.size() <= 20 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             (data.get('description', '') is string && data.get('description', '').size() <= 1000) &&
             (data.get('subcategory', '') is string && data.get('subcategory', '').size() <= 50) &&
             (data.get('image', '') is string && data.get('image', '').size() <= 500) &&
             (data.get('isPopular', false) is bool) &&
             (data.get('deleted', false) is bool);
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true; // Public menu
      
      allow create: if isAdmin() && 
                      isValidId(productId) && 
                      isValidMenuItem(incoming());
      
      allow update: if isAdmin() && 
                      isValidMenuItem(incoming()) && (
                        // Full update for admin
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'name', 'description', 'price', 'category', 'subcategory', 'image', 'isPopular', 'deleted'
                        ])
                      );
      
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via Admin SDK or Console
    }
  }
}
